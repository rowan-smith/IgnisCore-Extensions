    <module>paint-stripper</module>
    <module>stencil-plate</module>
    <module>sandblaster</module>
    <module>mulch-spreader</module>
    <module>gravity-marble</module>
    <module>quantum-coin</module>
    <module>lamp-dimmer</module>
    <module>gate-clicker</module>
    <module>sprinkler-timer</module>
    <module>farm-call</module>
    <module>valve-wrench</module>
