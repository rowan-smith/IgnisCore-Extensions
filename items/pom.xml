    <module>heavy-coat-tonic</module>
    <module>honey-throat-coat</module>
    <module>chorus-bite</module>
    <module>glow-berry-shot</module>
    <module>bricklayers-broth</module>
    <module>luck-dust</module>
    <module>antidote-swab</module>
    <module>unlabeled-potion</module>
    <module>fragmentation-grenade</module>
    <module>flashbang</module>
    <module>cryo-grenade</module>
    <module>smoke-grenade</module>
    <module>sticky-bomb</module>
